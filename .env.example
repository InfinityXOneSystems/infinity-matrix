# Infinity-Matrix Environment Configuration
# Copy this file to .env and fill in your actual values
# NEVER commit .env to version control!

# =============================================================================
# GitHub Configuration
# =============================================================================

# GitHub Personal Access Token (for API access)
# Scopes needed: repo, workflow, write:packages
GITHUB_TOKEN=ghp_YOUR_GITHUB_TOKEN_HERE

# GitHub App Configuration
GITHUB_APP_ID=YOUR_APP_ID
GITHUB_APP_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\nYOUR_PRIVATE_KEY_HERE\n-----END RSA PRIVATE KEY-----"

# GitHub OAuth App Configuration
GITHUB_OAUTH_CLIENT_ID=YOUR_OAUTH_CLIENT_ID
GITHUB_OAUTH_CLIENT_SECRET=YOUR_OAUTH_CLIENT_SECRET

# =============================================================================
# Google Cloud Platform Configuration
# =============================================================================

# GCP Project ID
GCP_PROJECT_ID=infinity-matrix-prod

# Path to service account key file (relative to project root)
GOOGLE_APPLICATION_CREDENTIALS=./gcp-key.json

# GCP Region
GCP_REGION=us-central1

# =============================================================================
# Supabase Configuration
# =============================================================================

# Supabase Project URL
SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co

# Supabase Anonymous/Public Key (safe for client-side)
SUPABASE_ANON_KEY=YOUR_ANON_KEY_HERE

# Supabase Service Role Key (keep secret! server-side only)
SUPABASE_SERVICE_KEY=YOUR_SERVICE_ROLE_KEY_HERE

# Supabase Database Password (optional, for direct connections)
SUPABASE_DB_PASSWORD=YOUR_DB_PASSWORD

# =============================================================================
# Hostinger Configuration
# =============================================================================

# Hostinger FTP/SFTP Configuration
HOSTINGER_FTP_HOST=ftp.infinityxai.com
HOSTINGER_FTP_USER=your_ftp_username
HOSTINGER_FTP_PASS=your_ftp_password
HOSTINGER_FTP_PORT=21

# Website URL
WEBSITE_URL=https://infinityxai.com

# =============================================================================
# Application Configuration
# =============================================================================

# Environment (development, staging, production)
NODE_ENV=development

# Application Port
PORT=3000

# API Base URL
API_BASE_URL=http://localhost:3000/api

# =============================================================================
# Logging Configuration
# =============================================================================

# Log Level (debug, info, warn, error)
LOG_LEVEL=debug

# Log Format (json, pretty)
LOG_FORMAT=pretty

# =============================================================================
# Agent Configuration
# =============================================================================

# Agent Mode (development, production)
AGENT_MODE=development

# Agent Autonomy Level (low, medium, high)
AGENT_AUTONOMY=medium

# Maximum concurrent agent tasks
AGENT_MAX_CONCURRENT=5

# Agent task timeout (minutes)
AGENT_TASK_TIMEOUT=60

# =============================================================================
# Security Configuration
# =============================================================================

# JWT Secret (generate a random string)
JWT_SECRET=your_jwt_secret_here

# Session Secret (generate a random string)
SESSION_SECRET=your_session_secret_here

# Encryption Key (for sensitive data)
ENCRYPTION_KEY=your_encryption_key_here

# =============================================================================
# Monitoring & Alerting
# =============================================================================

# Slack Webhook URL (for notifications)
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL

# Email Configuration (for alerts)
EMAIL_FROM=alerts@infinityxai.com
EMAIL_TO=team@infinityxai.com

# SMTP Configuration (optional)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password

# =============================================================================
# Feature Flags
# =============================================================================

# Enable/disable features during development
FEATURE_AGENT_AUTOMATION=true
FEATURE_AUTO_DEPLOYMENT=false
FEATURE_AI_CODE_REVIEW=true
FEATURE_SECURITY_SCANNING=true

# =============================================================================
# Development Configuration
# =============================================================================

# Enable debug mode
DEBUG=false

# Enable verbose logging
VERBOSE=false

# Enable hot reload
HOT_RELOAD=true
