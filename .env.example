# Environment variables for Infinity Matrix

# Core configuration
INFINITY_MATRIX_DEBUG=false
INFINITY_MATRIX_LOG_LEVEL=INFO
INFINITY_MATRIX_DATA_DIR=~/.infinity-matrix

# GitHub integration
GITHUB_TOKEN=your_github_token_here
GITHUB_WEBHOOK_SECRET=your_webhook_secret_here

# Google Cloud Platform
GCP_PROJECT_ID=your_project_id
GOOGLE_APPLICATION_CREDENTIALS=/path/to/credentials.json

# Hostinger integration
HOSTINGER_API_KEY=your_api_key_here

# Database (if using PostgreSQL backend)
DATABASE_URL=postgresql://user:password@localhost:5432/infinity_matrix

# Redis (if using Redis backend or caching)
REDIS_URL=redis://localhost:6379/0

# API keys for AI models
OPENAI_API_KEY=your_openai_api_key
ANTHROPIC_API_KEY=your_anthropic_api_key

# Monitoring and observability
PROMETHEUS_PORT=9090
GRAFANA_PORT=3000

# Security
SECRET_KEY=your_secret_key_here
JWT_SECRET=your_jwt_secret_here
