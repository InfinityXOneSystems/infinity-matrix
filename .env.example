# GitHub Configuration
# ===================

# GitHub Personal Access Token or App Installation Token
# Required for API access to create PRs, issues, etc.
GITHUB_TOKEN=your_github_token_here

# GitHub App Configuration (if using GitHub App)
# ----------------------------------------------
# GitHub App ID (numeric ID from app settings)
GITHUB_APP_ID=123456

# Path to GitHub App private key file
GITHUB_PRIVATE_KEY_PATH=/path/to/private-key.pem

# GitHub App Installation ID (if using installation token)
GITHUB_APP_INSTALLATION_ID=12345678

# Repository Configuration
# ========================

# Repository owner/organization
GITHUB_OWNER=InfinityXOneSystems

# Repository name
GITHUB_REPO=infinity-matrix

# Default branch name
GITHUB_DEFAULT_BRANCH=main

# Agent Configuration
# ===================

# Agent operation mode:
# - dry-run: No changes, logging only (RECOMMENDED for initial setup)
# - analysis: Read-only analysis and reporting
# - full: Can create PRs and make changes (use with caution)
AGENT_MODE=dry-run

# Enable detailed debug logging
DEBUG_MODE=false

# Maximum number of issues/PRs to analyze per run
MAX_ANALYSIS_ITEMS=50

# Workflow Configuration
# ======================

# Enable automatic PR creation
AUTO_CREATE_PR=false

# Require approval before auto-merging
REQUIRE_APPROVAL=true

# Auto-assign PRs to specific users (comma-separated)
AUTO_ASSIGN_USERS=

# Labels to add to auto-generated PRs (comma-separated)
AUTO_PR_LABELS=automated,bot

# Analysis Configuration
# ======================

# Enable code quality analysis
ENABLE_CODE_ANALYSIS=true

# Enable dependency vulnerability scanning
ENABLE_SECURITY_SCAN=true

# Enable repository health checks
ENABLE_HEALTH_CHECKS=true

# Minimum code quality score (0-100)
MIN_QUALITY_SCORE=70

# AI Stack Configuration (Future)
# ================================

# OpenAI API Key (uncomment when needed)
# OPENAI_API_KEY=sk-...

# Anthropic API Key (uncomment when needed)
# ANTHROPIC_API_KEY=sk-ant-...

# Model selection
# AI_MODEL=gpt-4
# AI_TEMPERATURE=0.7

# Gateway Stack Configuration (Future)
# =====================================

# External API endpoints
# API_GATEWAY_URL=https://api.example.com

# API authentication
# API_KEY=your_api_key_here

# Notification Configuration
# ==========================

# Slack webhook URL for notifications (optional)
# SLACK_WEBHOOK_URL=https://hooks.slack.com/services/...

# Discord webhook URL for notifications (optional)
# DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/...

# Email configuration (optional)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your-email@example.com
# SMTP_PASSWORD=your-password
# NOTIFICATION_EMAIL=team@example.com
