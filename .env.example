# Infinity Matrix Configuration

# Application Settings
INFINITY_APP_NAME="Infinity Matrix Auto-Builder"
INFINITY_APP_VERSION="0.1.0"
INFINITY_DEBUG=false
INFINITY_LOG_LEVEL="INFO"

# API Configuration
INFINITY_API_HOST="0.0.0.0"
INFINITY_API_PORT=8000
INFINITY_API_PREFIX="/api/v1"
INFINITY_CORS_ORIGINS="*"

# Security
INFINITY_SECRET_KEY="change-me-in-production-use-strong-random-key"
INFINITY_JWT_ALGORITHM="HS256"
INFINITY_ACCESS_TOKEN_EXPIRE_MINUTES=60

# Repository Configuration
INFINITY_REPO_BASE_PATH="./builds"
INFINITY_TEMPLATES_PATH="./templates"
INFINITY_BLUEPRINTS_PATH="./blueprints"

# GitHub Integration
# INFINITY_GITHUB_TOKEN="your-github-token"
# INFINITY_GITHUB_ORG="your-org"
INFINITY_GITHUB_BASE_URL="https://api.github.com"

# Agent Configuration
INFINITY_MAX_CONCURRENT_AGENTS=10
INFINITY_AGENT_TIMEOUT=300

# Build Configuration
INFINITY_MAX_CONCURRENT_BUILDS=5
INFINITY_BUILD_TIMEOUT=3600
INFINITY_CLEANUP_OLD_BUILDS=true
INFINITY_KEEP_BUILDS_DAYS=7

# CI/CD Configuration
INFINITY_ENABLE_AUTO_MERGE=false
INFINITY_ENABLE_AUTO_DEPLOY=false
INFINITY_VALIDATION_REQUIRED=true

# Database (optional)
# INFINITY_DATABASE_URL="postgresql://user:password@localhost/infinity_matrix"
