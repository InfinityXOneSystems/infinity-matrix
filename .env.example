# Environment Configuration

# System Configuration
ENVIRONMENT=production
LOG_LEVEL=INFO
DEBUG=False

# Google Cloud Platform
GCP_PROJECT_ID=your-project-id
GCP_REGION=us-central1
GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account-key.json

# Google Secret Manager
USE_SECRET_MANAGER=True
SECRET_PROJECT_ID=your-project-id

# OpenAI
OPENAI_API_KEY=your-openai-api-key
OPENAI_MODEL=gpt-4-turbo-preview

# Anthropic
ANTHROPIC_API_KEY=your-anthropic-api-key

# Google Vertex AI
VERTEX_AI_PROJECT=your-project-id
VERTEX_AI_LOCATION=us-central1

# GitHub
GITHUB_TOKEN=your-github-token
GITHUB_ORG=InfinityXOneSystems
GITHUB_REPO=infinity-matrix

# Twilio
TWILIO_ACCOUNT_SID=your-account-sid
TWILIO_AUTH_TOKEN=your-auth-token
TWILIO_PHONE_NUMBER=your-phone-number

# Google Workspace
GOOGLE_CALENDAR_ID=your-calendar-id
GOOGLE_DRIVE_FOLDER_ID=your-folder-id

# Database
DATABASE_URL=postgresql://user:password@localhost/infinity_matrix
REDIS_URL=redis://localhost:6379/0
FIRESTORE_COLLECTION=infinity_matrix

# API Configuration
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=4

# Web Configuration
WEB_HOST=0.0.0.0
WEB_PORT=3000
DOMAIN=infinityxai.com

# Monitoring
PROMETHEUS_PORT=9090
GRAFANA_PORT=3001
ENABLE_MONITORING=True

# Task Queue
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# Docker
DOCKER_REGISTRY=gcr.io
DOCKER_IMAGE_PREFIX=infinity-matrix

# Feature Flags
ENABLE_AUTO_PR=True
ENABLE_AUTO_DEPLOY=True
ENABLE_SELF_UPGRADE=True
ENABLE_COST_OPTIMIZATION=True

# Agent Configuration
AGENT_EXECUTION_TIMEOUT=300
AGENT_MAX_RETRIES=3
AGENT_DEBATE_ROUNDS=3

# SOP Configuration
AUTO_GENERATE_SOP=True
SOP_OUTPUT_PATH=docs/tracking/sops
