# Environment Configuration
# Copy this file to .env and configure with your actual values

# Database
POSTGRES_PASSWORD=your_secure_password_here
DATABASE_URL=postgresql://infinity_user:your_secure_password_here@localhost:5432/infinity_matrix

# Redis
REDIS_URL=redis://localhost:6379

# API Keys - Required for intelligence gathering
OPENAI_API_KEY=sk-your-openai-key-here
ANTHROPIC_API_KEY=sk-ant-your-anthropic-key-here

# Optional: Additional AI providers
GOOGLE_API_KEY=your-google-api-key-here
SERPAPI_KEY=your-serpapi-key-here
BRAVE_SEARCH_API_KEY=your-brave-search-key-here

# Security
SECRET_KEY=your-secret-key-at-least-32-characters-long
JWT_SECRET_KEY=your-jwt-secret-key-here
API_KEY_SALT=your-api-key-salt-here

# Application Settings
ENVIRONMENT=development
DEBUG=true
LOG_LEVEL=INFO

# Frontend
REACT_APP_API_URL=http://localhost:8000
REACT_APP_WS_URL=ws://localhost:8000

# Rate Limiting
RATE_LIMIT_PER_MINUTE=60
RATE_LIMIT_PER_HOUR=1000

# Intelligence Engine Settings
MAX_CRAWL_DEPTH=3
MAX_CONCURRENT_REQUESTS=10
REQUEST_TIMEOUT=30
INTELLIGENCE_CACHE_TTL=3600

# LLM Settings
DEFAULT_LLM_MODEL=gpt-4-turbo-preview
DEFAULT_TEMPERATURE=0.7
MAX_TOKENS=4096

# Storage
UPLOAD_DIR=/tmp/uploads
REPORT_OUTPUT_DIR=/tmp/reports
