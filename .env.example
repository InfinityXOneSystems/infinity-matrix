# System Configuration
ENVIRONMENT=development
DEBUG=true
LOG_LEVEL=INFO

# API Configuration
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=4

# Database
DATABASE_URL=sqlite:///./infinity_matrix.db
REDIS_URL=redis://localhost:6379/0

# Vision Cortex
VISION_MODEL=openai/clip-vit-base-patch32
VISION_BATCH_SIZE=32
VISION_MAX_IMAGE_SIZE=1024

# Agent Registry
AGENT_POOL_SIZE=10
AGENT_TIMEOUT=300

# Security
SECRET_KEY=change-me-in-production-use-secure-random-key
API_KEY_HEADER=X-API-Key

# Monitoring
PROMETHEUS_PORT=9090
ENABLE_TRACING=true
ENABLE_METRICS=true

# Auto-Builder
BUILDER_WORKSPACE=./workspace
BUILDER_MAX_CONCURRENT=5

# Proof Logs
LOGS_RETENTION_DAYS=90
LOGS_STORAGE_PATH=./logs
