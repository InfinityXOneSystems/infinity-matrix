# MCP Server Configuration
MCP_SERVER_PORT=3000
MCP_SERVER_HOST=0.0.0.0
MCP_SERVER_ENV=development
MCP_LOG_LEVEL=info

# Database Configuration
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=infinity_matrix
POSTGRES_USER=infinity_matrix
POSTGRES_PASSWORD=changeme
POSTGRES_URL=postgresql://infinity_matrix:changeme@localhost:5432/infinity_matrix

# Redis Configuration
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_URL=redis://localhost:6379

# OpenAI Configuration
OPENAI_API_KEY=sk-...
OPENAI_ORG_ID=org-...
OPENAI_MODEL=gpt-4-turbo-preview

# Google Cloud Configuration
GOOGLE_CLOUD_PROJECT=your-project-id
GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json
VERTEX_AI_LOCATION=us-central1
VERTEX_AI_MODEL=gemini-pro

# GitHub Configuration
GITHUB_TOKEN=ghp_...
GITHUB_APP_ID=123456
GITHUB_APP_PRIVATE_KEY_PATH=/path/to/private-key.pem
GITHUB_WEBHOOK_SECRET=your-webhook-secret

# VS Code Configuration
VSCODE_EXTENSION_ID=infinity-matrix.infinity-matrix
VSCODE_LANGUAGE_SERVER_PORT=6009

# Authentication
JWT_SECRET=your-jwt-secret-change-in-production
JWT_EXPIRY=24h
OAUTH_CLIENT_ID=your-oauth-client-id
OAUTH_CLIENT_SECRET=your-oauth-client-secret

# Google Workspace
GOOGLE_WORKSPACE_DOMAIN=your-domain.com
GOOGLE_WORKSPACE_ADMIN_EMAIL=admin@your-domain.com

# Hostinger Configuration
HOSTINGER_API_KEY=your-hostinger-api-key
HOSTINGER_DOMAIN=infinity-matrix.manus.im
HOSTINGER_FTP_HOST=ftp.your-domain.com
HOSTINGER_FTP_USER=your-ftp-user
HOSTINGER_FTP_PASSWORD=your-ftp-password

# Monitoring and Observability
SENTRY_DSN=https://...@sentry.io/...
DATADOG_API_KEY=your-datadog-key
PROMETHEUS_PORT=9090

# Feature Flags
ENABLE_VERTEX_AI=true
ENABLE_OPENAI=true
ENABLE_GITHUB_COPILOT=true
ENABLE_AUTO_MERGE=false
ENABLE_AUTO_APPROVE=false

# Rate Limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100

# Deployment
DEPLOY_ENVIRONMENT=production
DEPLOY_REGION=us-central1
