# Infinity Matrix Environment Configuration

# System Configuration
NODE_ENV=production
PORT=3000
HOST=0.0.0.0

# Service URLs
GATEWAY_URL=http://localhost:3000
ORCHESTRATOR_URL=http://localhost:3001
INTELLIGENCE_URL=http://localhost:3002
MONITORING_URL=http://localhost:3003

# Database Configuration
DATABASE_URL=postgresql://infinity:password@localhost:5432/infinity_matrix
REDIS_URL=redis://localhost:6379
ELASTICSEARCH_URL=http://localhost:9200

# Agent Configuration
AGENT_REGISTRY_PATH=./manifests/agents
AGENT_AUTO_DISCOVERY=true
AGENT_HEALTH_CHECK_INTERVAL=30000
AGENT_MAX_RESTARTS=3

# MCP Configuration
MCP_ENABLED=true
MCP_PROTOCOL_VERSION=1.0.0
MCP_MAX_CONNECTIONS=1000
MCP_TIMEOUT=30000

# Gateway Configuration
GATEWAY_RATE_LIMIT=100
GATEWAY_TIMEOUT=60000
GATEWAY_CORS_ENABLED=true
GATEWAY_AUTH_ENABLED=true

# Intelligence Configuration
INTELLIGENCE_AUTO_CRAWL=true
INTELLIGENCE_CRAWL_INTERVAL=3600000
INTELLIGENCE_DATA_RETENTION_DAYS=90

# Orchestration Configuration
ORCHESTRATION_MAX_PARALLEL_WORKFLOWS=10
ORCHESTRATION_WORKFLOW_TIMEOUT=3600000
ORCHESTRATION_RETRY_ATTEMPTS=3

# Monitoring Configuration
MONITORING_ENABLED=true
MONITORING_METRICS_PORT=9090
MONITORING_HEALTH_CHECK_PORT=8080
MONITORING_LOG_LEVEL=info

# Security Configuration
JWT_SECRET=your-secret-key-change-in-production
JWT_EXPIRY=24h
API_KEY=your-api-key-change-in-production
ENCRYPTION_KEY=your-encryption-key-change-in-production

# Communication Configuration
WEBSOCKET_ENABLED=true
WEBSOCKET_PORT=3100
REALTIME_UPDATES=true

# Backup Configuration
BACKUP_ENABLED=true
BACKUP_SCHEDULE=0 0 * * *
BACKUP_RETENTION_DAYS=30
BACKUP_PATH=./backups

# External Integrations
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_CLOUD_PROJECT=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AZURE_SUBSCRIPTION_ID=

# Industry-Specific Settings
ENABLE_REAL_ESTATE=true
ENABLE_HEALTHCARE=false
ENABLE_FINANCE=false
ENABLE_MANUFACTURING=false
ENABLE_RETAIL=false

# Feature Flags
FEATURE_AUTO_SCALING=true
FEATURE_LOAD_BALANCING=true
FEATURE_BLUE_GREEN_DEPLOY=false
FEATURE_CANARY_DEPLOY=false
FEATURE_CIRCUIT_BREAKER=true

# Performance Tuning
MAX_MEMORY_MB=4096
MAX_CPU_CORES=4
WORKER_THREADS=4
CACHE_TTL_SECONDS=300

# Audit and Compliance
AUDIT_ENABLED=true
AUDIT_LOG_PATH=./logs/audit
COMPLIANCE_MODE=strict
GDPR_ENABLED=false
HIPAA_ENABLED=false
SOC2_ENABLED=false
